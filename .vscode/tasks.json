{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Docker Image",
            "type": "shell",
            "command": "docker build -t juliansantosinfo/github-runner-linux-x64:2.332.0 .",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run Docker Image",
            "type": "shell",
            "command": "./run.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Stop Docker Image",
            "type": "shell",
            "command": "docker stop github-runner",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}