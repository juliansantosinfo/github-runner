{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Local (amd64)",
            "type": "shell",
            "command": "./build.sh local",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Setup Buildx (QEMU + multiarch builder)",
            "type": "shell",
            "command": "./build.sh setup",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build & Push Multi-Arch (amd64 + arm64 + arm/v7)",
            "type": "shell",
            "command": "./build.sh multi",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Run Docker Container",
            "type": "shell",
            "command": "./run.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Stop Docker Container",
            "type": "shell",
            "command": "docker stop github-runner",
            "group": {
                "kind": "test",
                "isDefault": false
            }
        }
    ]
}