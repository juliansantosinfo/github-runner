# GitHub Runner — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os seus valores:
#   cp .env.example .env

# Versão do GitHub Actions Runner (deve ser igual ao arquivo VERSION)
RUNNER_VERSION=2.332.0

# Nome do repositório alvo no GitHub
GITHUB_REPO_NAME=

# Usuário ou organização dona do repositório
GITHUB_REPO_OWNER=

# Personal Access Token com permissão `repo`
# Gere em: https://github.com/settings/tokens
GITHUB_PAT=

# Se true, o runner criará um diretório de trabalho com o nome do contêiner
GITHUB_CUSTOM_WORK_PATH=true
